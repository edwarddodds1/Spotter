{
  "name": "spotter",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && node scripts/postexport-web-icons.mjs",
    "preview:web": "npx serve dist",
    "typecheck": "tsc --noEmit",
    "sprites:transparent": "node scripts/apply-sprite-sheet-transparency.mjs",
    "line-art:split": "node scripts/split-line-art-doodles.mjs",
    "line-art:widen-cavalier": "node scripts/widen-cavalier-line-art.mjs",
    "line-art:process-cavalier": "node scripts/process-cavalier-line-art.mjs",
    "uncommon:sprite:transparent": "node scripts/apply-sprite-sheet-transparency.mjs",
    "uncommon:sprite:crops": "node scripts/analyze-uncommon-sprite-crops.mjs",
    "sprites:sync": "node scripts/sync-sprite-crops.mjs",
    "rare:sprite:transparent": "node scripts/apply-sprite-sheet-transparency.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@supabase/supabase-js": "^2.103.3",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-file-system": "~19.0.17",
    "expo-font": "~14.0.11",
